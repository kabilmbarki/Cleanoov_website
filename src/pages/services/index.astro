---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const services = [
  {
    id: "nettoyage",
    eyebrow: "Service · 01",
    title: "Nettoyage de panneaux",
    image: "/imgs/chantiers/chantier-detail.jpg",
    intro:
      "Le sable, la poussière et les fientes peuvent réduire le rendement d'une installation jusqu'à 25 %. Notre intervention restaure la production et prolonge la durée de vie des panneaux.",
    method: [
      { n: "01", title: "Audit & diagnostic", text: "Inspection visuelle et thermique, évaluation du soiling, mesure des pertes." },
      { n: "02", title: "Plan d'intervention", text: "Sélection de la méthode (à sec, eau dosée, robotisée selon le site) et planning." },
      { n: "03", title: "Opération sur site", text: "Équipe qualifiée, matériel dédié, eau déminéralisée à dosage maîtrisé." },
      { n: "04", title: "Reporting", text: "Rapport photo + courbe de rendement avant/après et recommandations de maintenance." },
    ],
  },
  {
    id: "installation",
    eyebrow: "Service · 02",
    title: "Installation photovoltaïque",
    image: "/imgs/chantiers/chantier-toit.jpg",
    intro:
      "De l'étude à la mise en service, nous concevons et installons des systèmes adaptés à votre site, en toiture industrielle, sur ombrière ou au sol.",
    method: [
      { n: "01", title: "Étude de site", text: "Visite technique, analyse d'ensoleillement, dimensionnement précis selon vos besoins." },
      { n: "02", title: "Conception", text: "Plans, schémas électriques, choix des composants (modules, onduleurs, structure)." },
      { n: "03", title: "Pose", text: "Installation par notre équipe certifiée, dans le respect des normes en vigueur." },
      { n: "04", title: "Mise en service & suivi", text: "Tests, raccordement, formation utilisateur, monitoring de production." },
    ],
  },
];
---

<BaseLayout
  title="Services — Nettoyage et installation photovoltaïque | Cleanoov"
  description="Deux savoir-faire complémentaires : nettoyage et installation de panneaux solaires pour industriels et collectivités en Tunisie."
>
  <!-- Hero page -->
  <section class="pt-16 lg:pt-24 pb-12 border-b border-line">
    <div class="container-wide">
      <p class="eyebrow reveal">Nos services</p>
      <h1 class="mt-8 max-w-4xl reveal" style="text-wrap: balance;">
        Du chantier neuf à la maintenance,
        <span class="gradient-solar italic font-semibold">une expertise complète</span>.
      </h1>
      <p class="mt-8 max-w-2xl text-lg text-ink-soft reveal">
        Cleanoov accompagne ses clients sur l'ensemble du cycle de vie d'une installation
        solaire, avec une exigence d'ingénierie et un ancrage local fort.
      </p>
    </div>
  </section>

  {
    services.map((s, i) => (
      <section
        id={s.id}
        class:list={[
          "py-24 lg:py-32",
          i % 2 === 1 ? "border-t border-line bg-bg-elev/40" : "",
        ]}
      >
        <div class="container-wide">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
            <div class="lg:col-span-5 reveal">
              <p class="eyebrow">{s.eyebrow}</p>
              <h2 class="mt-6">{s.title}</h2>
              <p class="mt-6 text-lg text-ink-soft leading-relaxed">{s.intro}</p>
              <a href="/contact" class="mt-9 inline-flex btn btn-primary">
                Discuter d'un projet
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <div class="lg:col-span-7 reveal">
              <div class="aspect-[4/3] overflow-hidden rounded-xl border border-line">
                <img
                  src={s.image}
                  alt={s.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          </div>

          <div class="mt-20">
            <p class="eyebrow reveal">Notre méthode</p>
            <ol class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
              {s.method.map((m) => (
                <li class="reveal surface p-6 lg:p-7">
                  <span class="font-mono text-[0.72rem] tracking-[0.18em] text-solar-bright">
                    {m.n}
                  </span>
                  <h3 class="mt-3 font-display text-xl text-ink leading-tight">
                    {m.title}
                  </h3>
                  <p class="mt-3 text-ink-soft text-sm leading-relaxed">
                    {m.text}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    ))
  }

  <CtaBanner
    title="Un site, un besoin précis ? Parlons-en."
    subtitle="Chaque installation est unique. Décrivez-nous votre contexte, nous revenons vers vous avec une proposition adaptée."
  />
</BaseLayout>
