---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const services = [
  {
    id: "nettoyage",
    eyebrow: "Service 01",
    title: "Nettoyage de panneaux",
    image: "/imgs/robot_brush_3.jpg",
    intro:
      "Le sable, la poussière et les fientes peuvent réduire le rendement d'une installation jusqu'à 25 %. Notre intervention restaure la production et prolonge la durée de vie des panneaux.",
    method: [
      {
        n: "01",
        title: "Audit & diagnostic",
        text: "Inspection visuelle et thermique, évaluation du taux de soiling, mesure des pertes.",
      },
      {
        n: "02",
        title: "Plan d'intervention",
        text: "Sélection de la méthode (sec, eau dosée, robotisée selon le site) et planning.",
      },
      {
        n: "03",
        title: "Opération sur site",
        text: "Équipe qualifiée, matériel dédié, eau déminéralisée à dosage maîtrisé.",
      },
      {
        n: "04",
        title: "Reporting",
        text: "Rapport photo + courbe de rendement avant/après. Recommandations de maintenance.",
      },
    ],
  },
  {
    id: "installation",
    eyebrow: "Service 02",
    title: "Installation photovoltaïque",
    image: "/imgs/supervision_panneaux_8.jpg",
    intro:
      "De l'étude à la mise en service, nous concevons et installons des systèmes adaptés à votre site, que ce soit en toiture industrielle, sur ombrière ou au sol.",
    method: [
      {
        n: "01",
        title: "Étude de site",
        text: "Visite technique, analyse d'ensoleillement, dimensionnement précis selon vos besoins.",
      },
      {
        n: "02",
        title: "Conception",
        text: "Plans, schémas électriques, choix des composants (modules, onduleurs, structure).",
      },
      {
        n: "03",
        title: "Pose",
        text: "Installation par notre équipe certifiée, dans le respect des normes en vigueur.",
      },
      {
        n: "04",
        title: "Mise en service & suivi",
        text: "Tests, raccordement, formation utilisateur, monitoring de production.",
      },
    ],
  },
];
---

<BaseLayout
  title="Services — Nettoyage et installation photovoltaïque | Cleanoov"
  description="Deux savoir-faire complémentaires : nettoyage et installation de panneaux solaires pour industriels et collectivités en Tunisie."
>
  <!-- Hero page -->
  <section class="pt-12 lg:pt-20 pb-12">
    <div class="container-wide">
      <p class="eyebrow">Nos services</p>
      <h1 class="mt-6 max-w-4xl">
        Du chantier neuf à la maintenance,<br />
        <span class="italic text-ocre">une expertise complète</span>.
      </h1>
      <p class="mt-8 max-w-2xl text-lg text-ink-soft">
        Cleanoov accompagne ses clients sur l'ensemble du cycle de vie d'une installation
        solaire, avec une exigence d'ingénierie et un ancrage local fort.
      </p>
    </div>
  </section>

  {
    services.map((s, i) => (
      <section
        id={s.id}
        class:list={[
          "py-20 lg:py-28",
          i % 2 === 1 ? "bg-cream-warm" : "",
        ]}
      >
        <div class="container-wide">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
            <div class="lg:col-span-5 reveal">
              <p class="eyebrow text-ocre">{s.eyebrow}</p>
              <h2 class="mt-4">{s.title}</h2>
              <p class="mt-6 text-lg text-ink-soft leading-relaxed">{s.intro}</p>
              <a href="/contact" class="mt-8 inline-flex btn btn-secondary">
                Discuter d'un projet
              </a>
            </div>
            <div class="lg:col-span-7 reveal">
              <div class="aspect-[4/3] overflow-hidden bg-sand rounded-sm">
                <img
                  src={s.image}
                  alt={s.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          </div>

          <div class="mt-16 lg:mt-20">
            <p class="eyebrow reveal">Notre méthode</p>
            <ol class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
              {s.method.map((m) => (
                <li class="reveal">
                  <span class="font-display text-ocre text-sm">{m.n}</span>
                  <h3 class="mt-2 font-display text-xl text-ink">{m.title}</h3>
                  <p class="mt-3 text-ink-soft text-sm leading-relaxed">{m.text}</p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    ))
  }

  <CtaBanner
    title="Un site, un besoin précis ? Parlons-en."
    subtitle="Chaque installation est unique. Décrivez-nous votre contexte, nous revenons vers vous avec une proposition adaptée."
  />
</BaseLayout>
