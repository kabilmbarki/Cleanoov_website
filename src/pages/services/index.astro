---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CtaBanner from "../../components/CtaBanner.astro";

const services = [
  {
    id: "nettoyage-semi-auto",
    eyebrow: "Service · 01",
    title: "Nettoyage semi-automatique des panneaux solaires",
    image: "/imgs/chantiers/chantier-06.jpg",
    intro:
      "Un système de brosses semi-automatiques permettant un nettoyage efficace, rapide et économe en eau, tout en protégeant les panneaux.",
    method: [
      { n: "01", title: "Audit initial", text: "Visite, évaluation du soiling, mesure des pertes de production sur le site." },
      { n: "02", title: "Sélection des brosses", text: "Type de brosse adapté au profil du panneau et à la configuration de l'installation." },
      { n: "03", title: "Intervention", text: "Brossage semi-automatique avec eau déminéralisée à dosage maîtrisé — gestes précis, faible consommation." },
      { n: "04", title: "Reporting", text: "Rapport photo + courbe de rendement avant/après pour mesurer le gain réel." },
    ],
  },
  {
    id: "robot",
    eyebrow: "Service · 02",
    title: "Robot de nettoyage pour grandes installations",
    image: "/imgs/chantiers/chantier-detail.jpg",
    intro:
      "Une solution automatisée destinée aux centrales solaires et grandes surfaces photovoltaïques, conçue pour réduire les coûts, le temps d'intervention et améliorer le rendement énergétique.",
    method: [
      { n: "01", title: "Étude de site", text: "Topographie, dimensions, accès, exposition au sable et aux poussières." },
      { n: "02", title: "Programmation", text: "Séquences de nettoyage adaptées à la disposition des modules et à la fréquence d'encrassement." },
      { n: "03", title: "Déploiement robot", text: "Opération autonome sur la centrale, supervisée par notre équipe technique." },
      { n: "04", title: "Suivi rendement", text: "Métriques de production avant / après et calendrier de passages optimisé." },
    ],
  },
  {
    id: "maintenance",
    eyebrow: "Service · 03",
    title: "Maintenance des installations photovoltaïques",
    image: "/imgs/illustrations/maintenance.jpg",
    intro:
      "Inspection et contrôle des systèmes PV pour garantir leur bon fonctionnement et détecter les anomalies techniques.",
    method: [
      { n: "01", title: "Visite périodique", text: "Inspection visuelle complète des modules, câblages, supports et raccordements." },
      { n: "02", title: "Mesures électriques", text: "Tests Voc, Vmp, Imp et isolation pour caractériser l'état réel de l'installation." },
      { n: "03", title: "Détection anomalies", text: "Modules défaillants, connexions oxydées, défauts onduleur — repérage et qualification." },
      { n: "04", title: "Rapport technique", text: "Document détaillé avec actions correctives priorisées et budget indicatif." },
    ],
  },
  {
    id: "diagnostic-preventif",
    eyebrow: "Service · 04",
    title: "Diagnostic et maintenance préventive",
    image: "/imgs/chantiers/chantier-toit.jpg",
    intro:
      "Analyse régulière des performances pour anticiper les pertes de rendement et assurer une production optimale sur le long terme.",
    method: [
      { n: "01", title: "Convention annuelle", text: "Périmètre, fréquence des visites, indicateurs suivis, niveau de service garanti." },
      { n: "02", title: "Imagerie thermique IR", text: "Caméra thermique à chaque passage pour détecter hot-spots et dégradations précoces." },
      { n: "03", title: "Analyse production", text: "Corrélation des courbes de production avec les conditions météo — alertes anticipées." },
      { n: "04", title: "Reporting périodique", text: "Visibilité long-terme sur la performance de votre actif avec recommandations." },
    ],
  },
];
---

<BaseLayout
  title="Nettoyage, diagnostic et maintenance de panneaux solaires en Tunisie | Cleanoov"
  description="Cleanoov, jeune startup tunisienne d'innovation solaire. Nettoyage robotisé, diagnostic thermique infrarouge et maintenance préventive de centrales photovoltaïques. Tunis, Sousse, Monastir, Sfax, Béjà — restaurez jusqu'à +25 % de rendement."
>
  <!-- Hero page -->
  <section class="pt-16 lg:pt-24 pb-12 border-b border-line">
    <div class="container-wide">
      <p class="eyebrow reveal">Nos services</p>
      <h1 class="mt-8 max-w-4xl reveal" style="text-wrap: balance;">
        Une approche
        <span class="gradient-solar italic font-semibold">complète</span>,
        bien au-delà du simple nettoyage.
      </h1>
      <p class="mt-8 max-w-2xl text-lg text-ink-soft reveal">
        Cleanoov optimise les performances des installations photovoltaïques
        à travers quatre métiers complémentaires — du nettoyage semi-automatique
        au robot autonome, de la maintenance terrain au diagnostic préventif
        piloté par IA.
      </p>
    </div>
  </section>

  {
    services.map((s, i) => (
      <section
        id={s.id}
        class:list={[
          "py-24 lg:py-32",
          i % 2 === 1 ? "border-t border-line bg-bg-elev/40" : "",
        ]}
      >
        <div class="container-wide">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
            <div class="lg:col-span-5 reveal">
              <p class="eyebrow">{s.eyebrow}</p>
              <h2 class="mt-6">{s.title}</h2>
              <p class="mt-6 text-lg text-ink-soft leading-relaxed">{s.intro}</p>
              <a href="/contact" class="mt-9 inline-flex btn btn-primary">
                Discuter d'un projet
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <div class="lg:col-span-7 reveal">
              <div class="aspect-[4/3] overflow-hidden rounded-xl border border-line">
                <img
                  src={s.image}
                  alt={s.title}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
          </div>

          <div class="mt-20">
            <p class="eyebrow reveal">Notre méthode</p>
            <ol class="mt-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
              {s.method.map((m) => (
                <li class="reveal surface p-6 lg:p-7">
                  <span class="font-mono text-[0.72rem] tracking-[0.18em] text-solar-bright">
                    {m.n}
                  </span>
                  <h3 class="mt-3 font-display text-xl text-ink leading-tight">
                    {m.title}
                  </h3>
                  <p class="mt-3 text-ink-soft text-sm leading-relaxed">
                    {m.text}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    ))
  }

  <CtaBanner
    title="Un site, un besoin précis ? Parlons-en."
    subtitle="Chaque centrale est unique. Décrivez-nous votre contexte, nous revenons vers vous avec une proposition adaptée."
  />
</BaseLayout>
