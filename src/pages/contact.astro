---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — Demander un devis | Cleanoov"
  description="Discutons de votre projet solaire. Audit, devis, ou simple échange — notre équipe vous répond sous 48h."
>
  <section class="pt-12 lg:pt-20 pb-24 lg:pb-32">
    <div class="container-wide">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Left: info -->
        <div class="lg:col-span-5 reveal">
          <p class="eyebrow">Contact</p>
          <h1 class="mt-6">
            Parlons de votre <span class="italic text-ocre">projet</span>.
          </h1>
          <p class="mt-6 text-lg text-ink-soft leading-relaxed">
            Décrivez-nous votre site, vos objectifs ou vos contraintes. Notre équipe
            revient vers vous sous 48 heures ouvrées avec une première analyse.
          </p>

          <dl class="mt-10 space-y-6 border-t border-ink/10 pt-8">
            <div>
              <dt class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
                Téléphone
              </dt>
              <dd class="mt-2 font-display text-2xl">
                <a href="tel:+216000000000" class="link-underline">+216 00 000 000</a>
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
                Email
              </dt>
              <dd class="mt-2 font-display text-xl">
                <a href="mailto:contact@cleanoov.com" class="link-underline">
                  contact@cleanoov.com
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
                Adresse
              </dt>
              <dd class="mt-2 text-ink-soft">
                À compléter<br />Tunis, Tunisie
              </dd>
            </div>
            <div>
              <dt class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
                Horaires
              </dt>
              <dd class="mt-2 text-ink-soft">
                Lun – Ven · 9h00 – 18h00
              </dd>
            </div>
          </dl>
        </div>

        <!-- Right: form (Netlify Forms) -->
        <div class="lg:col-span-7 reveal">
          <div class="bg-cream-warm border border-ink/10 rounded-sm p-8 lg:p-10">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="grid grid-cols-1 md:grid-cols-2 gap-5"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label>Ne pas remplir : <input name="bot-field" /></label>
              </p>

              <label class="block">
                <span class="block text-xs uppercase tracking-[0.16em] text-graphite font-medium mb-2">
                  Nom complet *
                </span>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full bg-cream rounded-sm px-4 py-3 border border-ink/15 focus:outline-none focus:ring-2 focus:ring-ocre"
                />
              </label>

              <label class="block">
                <span class="block text-xs uppercase tracking-[0.16em] text-graphite font-medium mb-2">
                  Entreprise
                </span>
                <input
                  type="text"
                  name="company"
                  class="w-full bg-cream rounded-sm px-4 py-3 border border-ink/15 focus:outline-none focus:ring-2 focus:ring-ocre"
                />
              </label>

              <label class="block md:col-span-2">
                <span class="block text-xs uppercase tracking-[0.16em] text-graphite font-medium mb-2">
                  Email *
                </span>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full bg-cream rounded-sm px-4 py-3 border border-ink/15 focus:outline-none focus:ring-2 focus:ring-ocre"
                />
              </label>

              <label class="block md:col-span-2">
                <span class="block text-xs uppercase tracking-[0.16em] text-graphite font-medium mb-2">
                  Type de projet
                </span>
                <select
                  name="type"
                  class="w-full bg-cream rounded-sm px-4 py-3 border border-ink/15 focus:outline-none focus:ring-2 focus:ring-ocre"
                >
                  <option value="">Choisir…</option>
                  <option value="nettoyage">Nettoyage</option>
                  <option value="installation">Installation</option>
                  <option value="audit">Audit / diagnostic</option>
                  <option value="autre">Autre</option>
                </select>
              </label>

              <label class="block md:col-span-2">
                <span class="block text-xs uppercase tracking-[0.16em] text-graphite font-medium mb-2">
                  Message *
                </span>
                <textarea
                  name="message"
                  rows="5"
                  required
                  placeholder="Décrivez votre projet, votre site, vos objectifs…"
                  class="w-full bg-cream rounded-sm px-4 py-3 border border-ink/15 focus:outline-none focus:ring-2 focus:ring-ocre resize-y"
                ></textarea>
              </label>

              <div class="md:col-span-2 flex items-center justify-between gap-4 pt-2">
                <p class="text-xs text-graphite">* Champs obligatoires</p>
                <button type="submit" class="btn btn-primary">
                  Envoyer la demande
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
