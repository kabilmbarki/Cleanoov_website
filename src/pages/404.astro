---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page introuvable — Cleanoov"
  description="Cette page n'existe pas. Retournez à l'accueil de Cleanoov, jeune startup tunisienne d'innovation solaire."
>
  <section class="min-h-[70vh] flex items-center py-24 lg:py-32">
    <div class="container-narrow text-center">
      <p class="eyebrow justify-center">Erreur · 404</p>
      <h1 class="mt-8" style="text-wrap: balance;">
        Cette page
        <span class="gradient-leaf italic font-semibold">a disparu</span>
        dans le sirocco.
      </h1>
      <p class="mt-8 max-w-xl mx-auto text-lg text-ink-soft">
        L'adresse que vous cherchez n'existe pas — ou plus. Pas de panique,
        voici de quoi rebondir.
      </p>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-3 lg:gap-4">
        <a href="/" class="btn btn-primary">
          Retour à l'accueil
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/services" class="btn btn-secondary">Nos services</a>
        <a href="/contact" class="btn btn-secondary">Nous contacter</a>
      </div>

      <ul class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
        <li class="surface p-6">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-muted">Nos succès</p>
          <a href="/#succes" class="mt-3 inline-block font-display text-lg text-ink hover:text-leaf transition-colors">
            Distinctions & compétitions →
          </a>
        </li>
        <li class="surface p-6">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-muted">Réalisations</p>
          <a href="/#realisations" class="mt-3 inline-block font-display text-lg text-ink hover:text-leaf transition-colors">
            Chantiers en Tunisie →
          </a>
        </li>
        <li class="surface p-6">
          <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-muted">Publications</p>
          <a href="/#publications" class="mt-3 inline-block font-display text-lg text-ink hover:text-leaf transition-colors">
            Stories & presse →
          </a>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
