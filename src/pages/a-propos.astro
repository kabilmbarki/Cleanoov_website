---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBanner from "../components/CtaBanner.astro";

const title =
  "À propos de Cleanoov — Vision, mission et valeurs d'une startup solaire tunisienne";
const description =
  "Découvrez Cleanoov : startup tunisienne d'innovation solaire. Notre vision pour la transition énergétique, notre mission de préservation des installations photovoltaïques, et les valeurs qui guident notre équipe.";

const valeurs = [
  {
    label: "Innovation",
    body: "Utiliser la technologie pour transformer la maintenance solaire.",
    icon: "spark",
  },
  {
    label: "Performance",
    body: "Viser toujours l'optimisation maximale des rendements.",
    icon: "trend",
  },
  {
    label: "Durabilité",
    body: "Préserver l'environnement et prolonger la vie des installations.",
    icon: "leaf",
  },
  {
    label: "Fiabilité",
    body: "Des solutions précises, efficaces et professionnelles.",
    icon: "shield",
  },
  {
    label: "Impact",
    body: "Contribuer activement à la transition énergétique.",
    icon: "target",
  },
];

const piliers = [
  {
    title: "Nettoyage adapté et optimisé",
    desc: "Calibré sur les besoins réels de chaque installation.",
  },
  {
    title: "Diagnostic intelligent",
    desc: "Lecture précise de la santé technique de votre centrale.",
  },
  {
    title: "Maintenance préventive · IA",
    desc: "Pilotée par intelligence artificielle, alertes anticipées.",
  },
];

// AboutPage JSON-LD — strengthens the entity graph for sitelinks & rich results.
const siteUrl = "https://cleanoov.tn/";
const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": `${siteUrl}a-propos#aboutpage`,
  url: `${siteUrl}a-propos`,
  name: "À propos de Cleanoov",
  description,
  inLanguage: "fr-TN",
  mainEntity: { "@id": `${siteUrl}#business` },
  isPartOf: { "@id": `${siteUrl}#website` },
};
---

<BaseLayout
  title={title}
  description={description}
  image="/og-a-propos.jpg"
  imageAlt="Cleanoov — Soulaymen Bayoudh, fondateur, présentant la startup solaire tunisienne · Vision, Mission, Valeurs"
>
  <!-- ─────────── PAGE INTRO ─────────── -->
  <section class="relative pt-36 lg:pt-44 pb-20 lg:pb-28 overflow-hidden border-b border-line">
    <div
      class="absolute inset-0 bg-[radial-gradient(900px_500px_at_85%_-5%,rgba(43,182,115,0.10),transparent_60%)] pointer-events-none"
      aria-hidden="true"
    ></div>

    <div class="container-narrow relative">
      <p class="eyebrow reveal">À propos · Cleanoov</p>

      <h1
        class="mt-10 font-display font-semibold text-[2.4rem] sm:text-[3.4rem] lg:text-[4.4rem] xl:text-[5rem] leading-[1] tracking-tight reveal"
        style="text-wrap: balance;"
      >
        Une <span class="gradient-leaf italic">jeune équipe tunisienne</span>
        qui pense le solaire comme un terrain de R&amp;D.
      </h1>

      <p class="mt-10 max-w-2xl text-lg lg:text-xl text-ink-soft leading-relaxed reveal">
        Startup tunisienne d'<span class="text-ink">innovation cleantech</span> —
        résidentiel, industrie, centrales au sol.
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-3 reveal">
        <span class="chip chip-leaf">Lauréat iptic · INNORPI</span>
        <span class="chip chip-leaf">Lauréat ctama · 2025</span>
        <span class="chip">Exposants JCI World Congress · 2026</span>
      </div>
    </div>
  </section>

  <!-- ─────────── VISION ─────────── -->
  <section class="relative py-28 lg:py-44 overflow-hidden border-b border-line">
    <span
      class="absolute pointer-events-none select-none -top-4 -right-4 sm:-top-6 sm:-right-8 lg:-top-12 lg:-right-16 font-display font-bold leading-[0.85] tracking-tighter text-leaf/[0.05] text-[7rem] sm:text-[12rem] lg:text-[20rem] xl:text-[26rem]"
      aria-hidden="true"
    >
      Vision.
    </span>

    <div class="container-narrow relative">
      <p class="eyebrow reveal">Notre vision</p>

      <h2
        class="mt-10 font-display font-semibold text-[2rem] sm:text-[2.6rem] lg:text-[3.4rem] xl:text-[4rem] leading-[1.08] tracking-tight reveal"
        style="text-wrap: balance;"
      >
        Devenir le
        <span class="gradient-leaf italic">leader en Tunisie et en Afrique</span>
        de l'optimisation intelligente du photovoltaïque.
      </h2>

      <div class="mt-14 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
        <p class="lg:col-span-7 text-lg lg:text-xl text-ink-soft leading-relaxed reveal">
          Rendre chaque système solaire
          <span class="text-ink">plus performant, durable et intelligent</span> —
          grâce à la technologie et à l'innovation.
        </p>
        <div class="lg:col-span-5 reveal">
          <div class="border-l-2 border-leaf pl-5">
            <p class="font-mono text-[0.7rem] uppercase tracking-[0.18em] text-ink-muted">
              Horizon 2030
            </p>
            <p class="mt-3 text-base text-ink leading-snug">
              La référence de l'optimisation photovoltaïque en
              Tunisie et en Afrique.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── MISSION ─────────── -->
  <section class="dark-section relative py-28 lg:py-44 overflow-hidden border-b border-line">
    <span
      class="absolute pointer-events-none select-none -bottom-6 -left-4 sm:-bottom-10 sm:-left-8 lg:-bottom-16 lg:-left-12 font-display font-bold leading-[0.85] tracking-tighter text-leaf/[0.10] text-[7rem] sm:text-[12rem] lg:text-[20rem] xl:text-[26rem]"
      aria-hidden="true"
    >
      Mission.
    </span>

    <div
      class="absolute inset-0 grid-bg grid-bg-fade opacity-30 pointer-events-none"
      aria-hidden="true"
    ></div>

    <div class="container-narrow relative">
      <p class="eyebrow reveal">Notre mission</p>

      <h2
        class="mt-10 font-display font-semibold text-[2rem] sm:text-[2.6rem] lg:text-[3.4rem] xl:text-[4rem] leading-[1.08] tracking-tight reveal"
        style="text-wrap: balance;"
      >
        <span class="gradient-leaf italic">Maximiser</span> la production
        solaire — réduire les pertes et les coûts de maintenance.
      </h2>

      <p class="mt-10 max-w-2xl text-lg lg:text-xl text-ink-soft leading-relaxed reveal">
        Des solutions complètes et accessibles à travers
        <span class="text-ink">trois métiers</span>, pour améliorer le
        rendement de chaque installation.
      </p>
    </div>

    <div class="container-wide mt-16 lg:mt-20 relative">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-5">
        {
          piliers.map((p, i) => (
            <article class="reveal group relative rounded-xl lg:rounded-2xl border border-line bg-surface p-7 lg:p-8 transition-colors duration-300 hover:border-leaf/40">
              <span class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-ink-muted">
                0{i + 1}
              </span>
              <h3 class="mt-4 font-display text-xl lg:text-[1.4rem] text-ink leading-tight">
                {p.title}
              </h3>
              <p class="mt-3 text-sm lg:text-[0.95rem] text-ink-soft leading-relaxed">
                {p.desc}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────── VALEURS ─────────── -->
  <section class="relative py-28 lg:py-44 overflow-hidden border-b border-line">
    <span
      class="absolute pointer-events-none select-none -top-6 left-1/2 -translate-x-1/2 font-display font-bold leading-[0.85] tracking-tighter text-leaf/[0.05] text-[7rem] sm:text-[12rem] lg:text-[20rem] xl:text-[26rem] whitespace-nowrap"
      aria-hidden="true"
    >
      Valeurs.
    </span>

    <div class="container-narrow relative">
      <p class="eyebrow reveal">Nos valeurs</p>

      <h2
        class="mt-10 font-display font-semibold text-[2rem] sm:text-[2.6rem] lg:text-[3.4rem] xl:text-[4rem] leading-[1.08] tracking-tight reveal"
        style="text-wrap: balance;"
      >
        Cinq principes — un seul cap :
        <span class="gradient-leaf italic">la performance solaire vérifiable</span>.
      </h2>
    </div>

    <div class="container-wide mt-16 lg:mt-20 relative">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 lg:gap-5">
        {
          valeurs.map((v) => (
            <article class="reveal group relative rounded-xl lg:rounded-2xl border border-line bg-surface p-7 lg:p-8 transition-colors duration-300 hover:border-leaf/40 h-full flex flex-col">
              <span class="inline-flex w-11 h-11 items-center justify-center rounded-full bg-leaf/10 text-leaf transition-transform duration-300 group-hover:scale-110">
                {v.icon === "spark" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 2v6M12 16v6M2 12h6M16 12h6M5 5l4 4M15 15l4 4M5 19l4-4M15 9l4-4" />
                  </svg>
                )}
                {v.icon === "trend" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M3 17l6-6 4 4 8-8" />
                    <path d="M14 7h7v7" />
                  </svg>
                )}
                {v.icon === "leaf" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M11 20A7 7 0 0 1 4 13c0-5 5-9 13-9 0 7-3 13-6 16z" />
                    <path d="M5 20l8-8" />
                  </svg>
                )}
                {v.icon === "shield" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z" />
                    <path d="M9 12l2 2 4-4" />
                  </svg>
                )}
                {v.icon === "target" && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="9" />
                    <circle cx="12" cy="12" r="5" />
                    <circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none" />
                  </svg>
                )}
              </span>

              <h3 class="mt-6 font-display text-xl lg:text-[1.35rem] text-ink leading-tight">
                {v.label}
              </h3>
              <p class="mt-3 text-sm lg:text-[0.95rem] text-ink-soft leading-relaxed">
                {v.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────── CTA ─────────── -->
  <CtaBanner />

  <!-- AboutPage structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(aboutPageSchema)} />
</BaseLayout>
