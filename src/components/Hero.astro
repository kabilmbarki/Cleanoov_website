---
// Hero — sobre, photo plein cadre + fade vers crème en bas
const stats = [
  { value: "30+", label: "Chantiers réalisés" },
  { value: "12 MW", label: "Installés ou nettoyés" },
  { value: "8", label: "Régions couvertes" },
];
---

<section class="relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <img
      src="/imgs/hero_background.png"
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-cream/30 via-cream/55 to-cream"
    >
    </div>
  </div>

  <div class="container-wide pt-24 lg:pt-32 pb-32 lg:pb-40">
    <div class="max-w-3xl">
      <p class="eyebrow">Tunisie · depuis 20XX</p>
      <h1 class="mt-6">
        Énergie solaire,<br />
        <span class="italic font-normal text-ocre">performance durable.</span>
      </h1>
      <p class="mt-8 text-lg lg:text-xl text-ink-soft max-w-2xl leading-relaxed">
        Nettoyage et installation de panneaux photovoltaïques pour industriels et
        collectivités. Une démarche d'ingénierie ancrée dans le terrain tunisien.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/contact" class="btn btn-primary">
          Demander un devis
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7h12m0 0L8 2m5 5L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/#realisations" class="btn btn-ghost">
          Voir nos réalisations
        </a>
      </div>
    </div>

    <dl class="mt-24 lg:mt-32 grid grid-cols-2 md:grid-cols-3 gap-8 max-w-3xl border-t border-ink/10 pt-10">
      {
        stats.map((s) => (
          <div>
            <dt class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
              {s.label}
            </dt>
            <dd class="mt-2 font-display text-3xl lg:text-4xl text-ink">
              {s.value}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
