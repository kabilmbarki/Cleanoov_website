---
// Calculateur ROI — version teaser, calcul réaliste mais simplifié
// Hypothèses (configurables) :
// - Production annuelle moyenne en Tunisie : ~1700 kWh/kWc/an (régions sud)
// - Tarif moyen industriel ~0,25 TND/kWh (à ajuster avec ton pote)
// - Perte par soiling annuel selon région : 8 à 22 %
const regions = [
  { name: "Tunis", loss: 10 },
  { name: "Sfax", loss: 14 },
  { name: "Sousse", loss: 12 },
  { name: "Gabès", loss: 17 },
  { name: "Tozeur", loss: 22 },
  { name: "Médenine", loss: 19 },
];
---

<section class="py-24 lg:py-32 bg-ink text-cream">
  <div class="container-default">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-end mb-12">
      <div class="lg:col-span-7 reveal">
        <p class="eyebrow text-cream/60">Outil</p>
        <h2 class="mt-4 text-cream">
          Combien le sable vous <span class="italic text-ocre">coûte-t-il</span> ?
        </h2>
      </div>
      <p class="lg:col-span-5 text-cream/70 reveal">
        Estimation rapide de la perte annuelle due au soiling, basée sur des
        moyennes régionales tunisiennes.
      </p>
    </div>

    <form
      class="reveal grid grid-cols-1 md:grid-cols-12 gap-4 lg:gap-6 bg-cream/5 backdrop-blur p-6 lg:p-8 rounded-sm border border-cream/10"
      data-roi-form
    >
      <label class="md:col-span-4 block">
        <span class="block text-xs uppercase tracking-[0.16em] text-cream/60 font-medium mb-2">
          Région
        </span>
        <select
          name="region"
          data-roi-region
          class="w-full bg-cream text-ink rounded-sm px-4 py-3 font-body border border-cream/20 focus:outline-none focus:ring-2 focus:ring-ocre"
        >
          {regions.map((r) => <option value={r.loss}>{r.name}</option>)}
        </select>
      </label>

      <label class="md:col-span-4 block">
        <span class="block text-xs uppercase tracking-[0.16em] text-cream/60 font-medium mb-2">
          Puissance (kWc)
        </span>
        <input
          type="number"
          name="size"
          data-roi-size
          min="1"
          step="1"
          value="500"
          class="w-full bg-cream text-ink rounded-sm px-4 py-3 font-body border border-cream/20 focus:outline-none focus:ring-2 focus:ring-ocre"
        />
      </label>

      <div class="md:col-span-4 flex items-end">
        <button type="submit" class="btn btn-primary w-full justify-center bg-ocre hover:bg-ocre-deep">
          Estimer
        </button>
      </div>
    </form>

    <div
      class="reveal mt-8 grid grid-cols-1 md:grid-cols-3 gap-px bg-cream/10 rounded-sm overflow-hidden"
      data-roi-result
      hidden
    >
      <div class="bg-ink p-6">
        <p class="text-xs uppercase tracking-[0.16em] text-cream/60 font-medium">Perte estimée</p>
        <p class="mt-3 font-display text-3xl text-ocre" data-roi-loss-pct>—</p>
        <p class="mt-1 text-sm text-cream/60">par an, sans nettoyage</p>
      </div>
      <div class="bg-ink p-6">
        <p class="text-xs uppercase tracking-[0.16em] text-cream/60 font-medium">Énergie perdue</p>
        <p class="mt-3 font-display text-3xl text-cream" data-roi-loss-kwh>—</p>
        <p class="mt-1 text-sm text-cream/60">kWh/an</p>
      </div>
      <div class="bg-ink p-6">
        <p class="text-xs uppercase tracking-[0.16em] text-cream/60 font-medium">Manque à gagner</p>
        <p class="mt-3 font-display text-3xl text-cream" data-roi-loss-money>—</p>
        <p class="mt-1 text-sm text-cream/60">TND/an</p>
      </div>
    </div>

    <p class="mt-6 text-xs text-cream/50 max-w-2xl">
      Hypothèses : production moyenne 1 700 kWh/kWc/an, tarif moyen 0,25 TND/kWh.
      Estimation indicative — un audit précis nécessite une visite sur site.
    </p>
  </div>
</section>

<script>
  const PROD_PER_KWC = 1700; // kWh / kWc / an
  const TARIFF = 0.25;       // TND / kWh

  const form = document.querySelector<HTMLFormElement>("[data-roi-form]");
  const result = document.querySelector<HTMLElement>("[data-roi-result]");
  const lossPctEl = document.querySelector<HTMLElement>("[data-roi-loss-pct]");
  const lossKwhEl = document.querySelector<HTMLElement>("[data-roi-loss-kwh]");
  const lossMoneyEl = document.querySelector<HTMLElement>("[data-roi-loss-money]");

  const fmt = new Intl.NumberFormat("fr-FR");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const region = Number(
      (form.querySelector("[data-roi-region]") as HTMLSelectElement)?.value ?? 10
    );
    const size = Math.max(
      1,
      Number((form.querySelector("[data-roi-size]") as HTMLInputElement)?.value ?? 0)
    );
    const lossKwh = size * PROD_PER_KWC * (region / 100);
    const lossMoney = lossKwh * TARIFF;

    if (lossPctEl) lossPctEl.textContent = `${region}%`;
    if (lossKwhEl) lossKwhEl.textContent = fmt.format(Math.round(lossKwh));
    if (lossMoneyEl) lossMoneyEl.textContent = fmt.format(Math.round(lossMoney));
    result?.removeAttribute("hidden");
  });
</script>
