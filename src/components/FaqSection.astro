---
// FAQ — answers to common questions, with FAQPage JSON-LD for rich results.
const faqs = [
  {
    q: "Pourquoi nettoyer ses panneaux solaires en Tunisie ?",
    a: "Le climat tunisien — sirocco, sable du sud, fientes, pluies de boue — peut faire chuter le rendement d'une centrale photovoltaïque de 15 à 25 %. Un nettoyage régulier restaure la production et prolonge la durée de vie des modules. Cleanoov intervient sur tout le territoire tunisien.",
  },
  {
    q: "Qui est Cleanoov ?",
    a: "Cleanoov est une jeune startup tunisienne d'innovation solaire, fondée en 2024. Lauréate du programme iptic (INNORPI) et du concours national ctama, exposante au JCI World Congress, elle conçoit des solutions de nettoyage robotisé et de maintenance préventive pour les centrales photovoltaïques.",
  },
  {
    q: "Quelles sont les villes couvertes par Cleanoov ?",
    a: "Nous intervenons dans tout le Nord et le Sahel tunisiens — Tunis, Sousse, Monastir, Sfax, Béjà — et nous déployons des missions dans le sud sur projet. Pour les sites isolés, nous proposons des contrats de maintenance préventive avec déplacements planifiés.",
  },
  {
    q: "Quelle est la différence entre nettoyage, diagnostic et maintenance préventive ?",
    a: "Le nettoyage restaure le rendement immédiat (jusqu'à +25 %). Le diagnostic technique identifie précisément les pertes via imagerie thermique infrarouge et inspection optique. La maintenance préventive est un contrat annuel avec visites planifiées, diagnostic préventif et alertes anticipées — pour sécuriser la production dans la durée.",
  },
  {
    q: "Combien de temps prend une intervention de nettoyage ?",
    a: "Cela dépend de la taille de la centrale et de la méthode retenue. Sur une toiture résidentielle, comptez quelques heures ; sur une centrale industrielle, une journée à plusieurs jours. Notre audit initial vous donnera un planning précis.",
  },
  {
    q: "Cleanoov utilise-t-elle de l'eau pour nettoyer les panneaux ?",
    a: "Oui, mais à dosage maîtrisé et en eau déminéralisée pour éviter toute trace ou agression de la surface des modules. Selon le site, nous combinons brossage robotisé et eau déminéralisée, ou intervention à sec. La méthode est choisie après diagnostic.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section id="faq" class="py-24 lg:py-32 border-t border-line">
  <div class="container-default">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-4 reveal">
        <p class="eyebrow">Questions fréquentes</p>
        <h2 class="mt-6" style="text-wrap: balance;">
          On répond
          <span class="gradient-leaf italic font-semibold">aux questions</span>
          que vous nous posez le plus.
        </h2>
        <p class="mt-6 text-ink-soft leading-relaxed">
          Nettoyage, diagnostic, maintenance — tout ce qu'il faut savoir avant
          de lancer une mission sur votre centrale solaire en Tunisie.
        </p>
      </div>

      <div class="lg:col-span-8">
        <ul class="divide-y divide-line border-y border-line">
          {
            faqs.map((f) => (
              <li class="reveal">
                <details class="group py-5 lg:py-6">
                  <summary class="flex items-start justify-between gap-6 cursor-pointer list-none">
                    <h3 class="font-display text-lg lg:text-xl text-ink leading-snug">
                      {f.q}
                    </h3>
                    <span
                      class="mt-1 shrink-0 w-7 h-7 rounded-full border border-line-strong flex items-center justify-center text-ink-soft group-open:bg-leaf group-open:border-leaf group-open:text-white transition-colors"
                      aria-hidden="true"
                    >
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="group-open:rotate-45 transition-transform">
                        <path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-4 text-ink-soft text-[0.95rem] leading-relaxed pr-12">
                    {f.a}
                  </p>
                </details>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
