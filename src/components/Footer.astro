---
const year = new Date().getFullYear();

const cols = [
  {
    title: "Innovation",
    links: [
      { href: "/#innovation", label: "Concours & distinctions" },
      { href: "/#publications", label: "Publications" },
      { href: "/#realisations", label: "Réalisations" },
    ],
  },
  {
    title: "Services",
    links: [
      { href: "/services#nettoyage", label: "Nettoyage" },
      { href: "/services#installation", label: "Installation" },
    ],
  },
  {
    title: "Contact",
    links: [
      { href: "/contact", label: "Demander un devis" },
      { href: "mailto:contact@cleanoov.com", label: "contact@cleanoov.com" },
      { href: "tel:+216000000000", label: "+216 00 000 000" },
    ],
  },
];
---

<footer class="relative mt-32 border-t border-line">
  <div
    class="absolute inset-0 grid-bg grid-bg-fade opacity-20 pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-wide py-20 relative">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-2">
          <img
            src="/imgs/brand/logo-dark.png"
            alt="Cleanoov"
            class="h-10 w-auto"
            width="500"
            height="500"
            loading="lazy"
          />
        </a>
        <p class="mt-6 text-sm leading-relaxed text-ink-soft max-w-xs">
          Startup tunisienne d'innovation solaire.<br />
          Lauréate <span class="text-ink">iptic</span> & <span class="text-ink">ctama</span>,
          exposants au congrès mondial JCI.
        </p>
        <div class="mt-6 flex items-center gap-2">
          <span class="dot-pulse" aria-hidden="true"></span>
          <span class="font-mono text-xs text-ink-muted uppercase tracking-[0.16em]">
            Tunis · Active
          </span>
        </div>
      </div>

      <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-3 gap-10">
        {
          cols.map((col) => (
            <div>
              <h4 class="font-mono text-[0.7rem] font-medium uppercase tracking-[0.18em] text-ink-muted">
                {col.title}
              </h4>
              <ul class="mt-5 space-y-3">
                {col.links.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      class="text-sm text-ink-soft hover:text-solar transition-colors"
                    >
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="mt-16 pt-8 border-t border-line flex flex-col md:flex-row gap-4 md:items-center md:justify-between text-xs text-ink-muted font-mono uppercase tracking-[0.14em]"
    >
      <p>© {year} Cleanoov · Tous droits réservés</p>
      <div class="flex gap-5 normal-case tracking-normal font-body">
        <a href="/mentions-legales" class="hover:text-ink transition-colors">Mentions légales</a>
        <a href="/confidentialite" class="hover:text-ink transition-colors">Confidentialité</a>
      </div>
    </div>
  </div>
</footer>
