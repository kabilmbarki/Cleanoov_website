---
// Réalisations vedettes — placeholders sourcés à remplacer par CMS plus tard
const projects = [
  {
    image: "/imgs/supervision_panneaux_3.png",
    location: "Sfax",
    year: "2024",
    type: "Installation",
    size: "450 kWc",
    title: "Toiture industrielle",
  },
  {
    image: "/imgs/robot_brush_9.webp",
    location: "Tozeur",
    year: "2024",
    type: "Nettoyage",
    size: "1,2 MW",
    title: "Centrale au sol",
  },
  {
    image: "/imgs/supervision_panneaux_6.png",
    location: "Gabès",
    year: "2025",
    type: "Installation",
    size: "2,5 MW",
    title: "Parc photovoltaïque",
  },
];
---

<section id="realisations" class="py-24 lg:py-32">
  <div class="container-wide">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div class="reveal">
        <p class="eyebrow">Sélection de projets</p>
        <h2 class="mt-4 max-w-xl">
          <span class="italic text-ocre">Réalisations</span> sur le terrain.
        </h2>
      </div>
      <p class="text-ink-soft max-w-md reveal">
        Une partie de nos chantiers récents — étude, pose ou maintenance, partout en Tunisie.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {
        projects.map((p) => (
          <article class="reveal group">
            <div class="relative aspect-[4/5] overflow-hidden bg-sand">
              <img
                src={p.image}
                alt={`${p.title} — ${p.location}`}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                loading="lazy"
              />
              <span class="absolute top-4 left-4 inline-flex items-center px-3 py-1.5 text-xs font-medium uppercase tracking-wider bg-cream text-ink rounded-full">
                {p.type}
              </span>
            </div>
            <div class="mt-5 flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-xl text-ink">{p.title}</h3>
                <p class="mt-1 text-sm text-graphite">
                  {p.location} · {p.year}
                </p>
              </div>
              <span class="font-display text-lg text-ocre whitespace-nowrap">
                {p.size}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
