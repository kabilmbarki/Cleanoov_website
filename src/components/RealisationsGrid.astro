---
// Real chantier gallery — asymmetric mosaic with real Cleanoov photos.
// Layout: 2 columns on tablet, 6-col bento on desktop.

const items = [
  {
    image: "/imgs/chantiers/chantier-jawhara.jpg",
    title: "Centrale Jawhara",
    location: "Sousse · Tunisie",
    type: "Nettoyage",
    span: "lg:col-span-3 lg:row-span-2",
    ratio: "aspect-[4/5]",
  },
  {
    image: "/imgs/chantiers/chantier-01.jpg",
    title: "Toiture industrielle",
    location: "Sfax · 2025",
    type: "Maintenance",
    span: "lg:col-span-3",
    ratio: "aspect-[16/10]",
  },
  {
    image: "/imgs/chantiers/chantier-toit.jpg",
    title: "Centrale en toiture",
    location: "Tunis · 2025",
    type: "Installation",
    span: "lg:col-span-3",
    ratio: "aspect-[16/10]",
  },
  {
    image: "/imgs/chantiers/chantier-02.jpg",
    title: "Audit & inspection",
    location: "Béjà · 2025",
    type: "Diagnostic",
    span: "lg:col-span-2",
    ratio: "aspect-[4/5]",
  },
  {
    image: "/imgs/chantiers/chantier-pres.jpg",
    title: "Présentation site",
    location: "Tunisie",
    type: "Mission",
    span: "lg:col-span-2",
    ratio: "aspect-[4/5]",
  },
  {
    image: "/imgs/chantiers/chantier-sousse.jpg",
    title: "Mission Sousse",
    location: "Sousse · 2025",
    type: "Nettoyage",
    span: "lg:col-span-2",
    ratio: "aspect-[4/5]",
  },
  {
    image: "/imgs/chantiers/chantier-04.jpg",
    title: "Centrale industrielle",
    location: "Tunisie",
    type: "Installation",
    span: "lg:col-span-3",
    ratio: "aspect-[16/10]",
  },
  {
    image: "/imgs/chantiers/chantier-detail.jpg",
    title: "Détail technique",
    location: "Atelier Cleanoov",
    type: "R&D",
    span: "lg:col-span-3",
    ratio: "aspect-[16/10]",
  },
];
---

<section id="realisations" class="relative py-28 lg:py-36">
  <div class="container-wide">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20">
      <div class="reveal max-w-2xl">
        <p class="eyebrow">Réalisations · Terrain</p>
        <h2 class="mt-6" style="text-wrap: balance;">
          <span class="gradient-leaf italic font-semibold">Sur le terrain</span>,
          partout en Tunisie.
        </h2>
      </div>
      <p class="text-ink-soft max-w-md reveal">
        Quelques chantiers récents — sites industriels, toitures, parcs au sol.
        Audit, installation ou maintenance.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 lg:gap-5">
      {
        items.map((it) => (
          <article
            class:list={[
              "reveal group relative overflow-hidden rounded-xl border border-line bg-surface",
              it.span,
              it.ratio,
            ]}
          >
            <img
              src={it.image}
              alt={`${it.title} — ${it.location}`}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
              loading="lazy"
            />
            <div
              class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,9,13,0.0)_30%,rgba(7,9,13,0.85)_100%)] opacity-90 transition-opacity duration-500 group-hover:opacity-100"
              aria-hidden="true"
            />

            <span class="absolute top-4 left-4 chip">
              {it.type}
            </span>

            <div class="absolute bottom-0 left-0 right-0 p-5 lg:p-6">
              <h3 class="font-display text-lg lg:text-xl text-ink leading-tight">
                {it.title}
              </h3>
              <p class="mt-1 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-muted">
                {it.location}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
