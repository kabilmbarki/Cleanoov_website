---
interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = "Parlons de votre projet.",
  subtitle = "Audit, devis ou simple échange — notre équipe vous répond sous 48h.",
} = Astro.props;
---

<section id="a-propos" class="py-24 lg:py-32">
  <div class="container-default">
    <div class="rounded-sm bg-cream-warm border border-ink/10 p-10 lg:p-16">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
        <div class="reveal max-w-2xl">
          <h2 class="text-ink">
            {title.split(".")[0]}<span class="text-ocre">.</span>
          </h2>
          <p class="mt-4 text-ink-soft text-lg">{subtitle}</p>
        </div>
        <div class="reveal flex flex-wrap gap-4">
          <a href="/contact" class="btn btn-primary">
            Demander un devis
          </a>
          <a href="tel:+216000000000" class="btn btn-secondary">
            +216 00 000 000
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
