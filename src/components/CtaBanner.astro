---
interface Props {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
}
const {
  title = "Parlons de votre projet.",
  subtitle = "Audit, devis ou simple échange — notre équipe vous répond sous 48h.",
  eyebrow = "Contact",
} = Astro.props;
---

<section id="cta" class="py-24 lg:py-32">
  <div class="container-default">
    <div
      class="relative rounded-2xl border border-line-strong overflow-hidden p-10 lg:p-16 surface-strong"
    >
      <!-- Glow -->
      <div
        class="absolute inset-0 pointer-events-none opacity-80"
        style="background: radial-gradient(700px 350px at 80% 20%, rgba(245,176,65,0.18), transparent 60%), radial-gradient(500px 300px at 0% 100%, rgba(47,191,110,0.12), transparent 60%);"
        aria-hidden="true"
      ></div>

      <div class="relative flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
        <div class="reveal max-w-2xl">
          <p class="eyebrow">{eyebrow}</p>
          <h2 class="mt-6" style="text-wrap: balance;">
            {title.split(".")[0]}<span class="text-solar">.</span>
          </h2>
          <p class="mt-5 text-ink-soft text-lg leading-relaxed">{subtitle}</p>
        </div>
        <div class="reveal flex flex-wrap gap-4 shrink-0">
          <a href="/contact" class="btn btn-primary">
            Demander un devis
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="tel:+216000000000" class="btn btn-secondary">
            +216 00 000 000
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
