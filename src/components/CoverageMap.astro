---
// Placeholder carte — remplacé par MapLibre en phase 2
// Pour le moment : SVG stylisé + liste de villes
const cities = [
  "Tunis", "Sfax", "Sousse", "Gabès",
  "Tozeur", "Kairouan", "Bizerte", "Médenine",
];
---

<section class="py-24 lg:py-32 bg-cream-warm">
  <div class="container-wide">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5 reveal">
        <p class="eyebrow">Couverture</p>
        <h2 class="mt-4">
          Présents partout en <span class="italic text-ocre">Tunisie</span>.
        </h2>
        <p class="mt-6 text-ink-soft text-lg leading-relaxed">
          Nos équipes interviennent du nord au sud, des toitures résidentielles
          aux centrales industrielles. Une carte interactive arrive bientôt —
          en attendant, voici nos zones d'intervention principales.
        </p>
        <ul class="mt-8 grid grid-cols-2 gap-x-6 gap-y-3 text-ink-soft">
          {
            cities.map((c) => (
              <li class="flex items-center gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-ocre" />
                {c}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-7 reveal">
        <div class="relative aspect-[4/3] bg-cream rounded-sm overflow-hidden border border-ink/10">
          <svg viewBox="0 0 400 300" class="w-full h-full" aria-hidden="true">
            <defs>
              <pattern id="dots" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
                <circle cx="2" cy="2" r="1" fill="#0f1a24" opacity="0.08" />
              </pattern>
            </defs>
            <rect width="400" height="300" fill="url(#dots)" />
            <!-- Stylized Tunisia silhouette -->
            <path
              d="M180 30 L210 35 L230 60 L240 90 L255 110 L260 140 L255 165 L240 185 L235 205 L225 230 L210 250 L195 265 L185 270 L175 260 L170 245 L165 220 L155 195 L150 170 L155 145 L160 120 L165 95 L170 70 L175 45 Z"
              fill="#c75d2b"
              opacity="0.12"
              stroke="#c75d2b"
              stroke-width="1.2"
            />
            <!-- Pin points (approximate) -->
            <g fill="#c75d2b">
              <circle cx="195" cy="55" r="4"><title>Tunis</title></circle>
              <circle cx="190" cy="75" r="3"><title>Bizerte</title></circle>
              <circle cx="210" cy="120" r="4"><title>Sousse</title></circle>
              <circle cx="215" cy="165" r="4"><title>Sfax</title></circle>
              <circle cx="180" cy="135" r="3"><title>Kairouan</title></circle>
              <circle cx="225" cy="200" r="3"><title>Gabès</title></circle>
              <circle cx="160" cy="200" r="3"><title>Tozeur</title></circle>
              <circle cx="220" cy="245" r="3"><title>Médenine</title></circle>
            </g>
          </svg>
          <p class="absolute bottom-4 right-4 text-xs text-graphite italic">
            Visualisation provisoire
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
