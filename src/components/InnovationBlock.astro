---
// Distinctions — vitrine éditoriale (1 featured + 2 satellites).
// Pas de timeline ni de carrousel : bento asymétrique avec une grande
// carte mise en valeur (ctama) et deux supports verticaux.

type Item = {
  n: string;
  year: string;
  title: string;
  tag: string;
  body: string;
  accent: "solar" | "leaf";
};

const featured: Item = {
  n: "02",
  year: "2025",
  title: "Lauréat du concours ctama",
  tag: "Award national",
  body: "Distingués au concours national ctama, vitrine des projets d'innovation industrielle tunisiens — une reconnaissance forte de notre approche du nettoyage robotisé.",
  accent: "solar",
};

const satellites: Item[] = [
  {
    n: "01",
    year: "2024",
    title: "Programme iptic",
    tag: "Incubation",
    body: "Sélectionnés parmi les startups les plus prometteuses du programme iptic, mené par l'INNORPI.",
    accent: "solar",
  },
  {
    n: "03",
    year: "2026",
    title: "JCI World Congress",
    tag: "International",
    body: "Cleanoov sélectionnée comme exposant officiel — vitrine de l'innovation jeune tunisienne au congrès mondial JCI.",
    accent: "leaf",
  },
];
---

<section id="succes" class="relative py-24 md:py-28 lg:py-36 overflow-hidden">
  <!-- ambient -->
  <div
    class="absolute inset-0 pointer-events-none opacity-50"
    style="background:radial-gradient(700px 400px at 15% 10%, rgba(43,182,115,0.10), transparent 60%), radial-gradient(700px 400px at 90% 90%, rgba(26,122,79,0.08), transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="container-wide relative">
    <!-- Header -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-end mb-12 lg:mb-16">
      <div class="lg:col-span-7 reveal">
        <p class="eyebrow">Nos succès · Distinctions</p>
        <h2 class="mt-6" style="text-wrap: balance;">
          Une approche
          <span class="gradient-solar italic font-semibold">validée</span>
          par les programmes cleantech les plus exigeants de la Tunisie.
        </h2>
      </div>
      <p class="lg:col-span-5 text-ink-soft text-[0.95rem] lg:text-base leading-relaxed reveal">
        Trois années, trois étapes : du soutien institutionnel local à
        l'exposition sur la scène mondiale — un parcours condensé qui
        ouvre déjà l'international.
      </p>
    </div>

    <!-- Bento : featured + 2 satellites -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-5">
      <!-- Featured card (dark for emphasis) -->
      <article
        class="dark-section reveal relative lg:col-span-7 lg:row-span-2 overflow-hidden rounded-2xl lg:rounded-3xl border border-leaf/40 bg-gradient-to-br from-[#0E2A1E] via-[#091A12] to-[#06120C] p-7 sm:p-9 lg:p-12 min-h-[380px] lg:min-h-0 flex flex-col"
      >
        <!-- Decorative giant year -->
        <span
          aria-hidden="true"
          class="absolute -right-4 -bottom-8 lg:-right-8 lg:-bottom-20 font-display font-semibold text-[8rem] sm:text-[12rem] md:text-[16rem] lg:text-[22rem] xl:text-[26rem] leading-none tracking-tighter text-leaf/[0.07] select-none pointer-events-none"
        >
          {featured.year}
        </span>
        <div
          class="absolute inset-0 pointer-events-none bg-[radial-gradient(500px_300px_at_85%_15%,rgba(43,182,115,0.20),transparent_60%)]"
          aria-hidden="true"
        ></div>
        <div class="absolute inset-0 grid-bg opacity-[0.05] pointer-events-none" aria-hidden="true"></div>

        <header class="relative flex items-center justify-between gap-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-leaf-bright">
            {featured.year} · N°{featured.n}
          </span>
          <span class="chip chip-leaf">{featured.tag}</span>
        </header>

        <div class="relative mt-auto pt-12 lg:pt-20">
          <div class="flex items-center gap-3 mb-5">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="text-leaf-bright">
              <path d="M12 2l2.39 6.95H22l-6.2 4.5 2.4 7.05L12 16l-6.2 4.5 2.4-7.05L2 8.95h7.61L12 2z" fill="currentColor"/>
            </svg>
            <span class="dot-pulse" style="width:8px;height:8px"></span>
          </div>

          <h3 class="font-display text-3xl sm:text-4xl lg:text-[2.6rem] xl:text-[3.1rem] leading-[1.05] text-ink" style="text-wrap: balance;">
            {featured.title}
          </h3>
          <p class="mt-5 lg:mt-6 max-w-xl text-ink-soft text-[0.95rem] lg:text-[1rem] leading-relaxed">
            {featured.body}
          </p>
        </div>
      </article>

      <!-- Satellite cards -->
      {
        satellites.map((it) => (
          <article
            class:list={[
              "reveal relative lg:col-span-5 overflow-hidden rounded-2xl border bg-bg-elev/60 p-7 lg:p-8 min-h-[200px] lg:min-h-0 flex flex-col",
              it.accent === "solar" ? "border-line hover:border-solar/30" : "border-line hover:border-leaf/30",
              "transition-colors",
            ]}
          >
            <span
              aria-hidden="true"
              class:list={[
                "absolute -right-3 -bottom-6 lg:-bottom-8 font-display font-semibold text-[6rem] sm:text-[8rem] lg:text-[10rem] leading-none tracking-tighter select-none pointer-events-none",
                it.accent === "solar" ? "text-solar/[0.05]" : "text-leaf/[0.06]",
              ]}
            >
              {it.year}
            </span>

            <header class="relative flex items-center justify-between gap-4">
              <span
                class:list={[
                  "font-mono text-[0.7rem] uppercase tracking-[0.2em]",
                  it.accent === "solar" ? "text-solar-bright" : "text-leaf-bright",
                ]}
              >
                {it.year} · N°{it.n}
              </span>
              <span
                class:list={[
                  "chip text-[0.65rem]",
                  it.accent === "solar" ? "chip-solar" : "chip-leaf",
                ]}
              >
                {it.tag}
              </span>
            </header>

            <div class="relative mt-auto pt-10 lg:pt-12">
              <h3 class="font-display text-xl lg:text-[1.55rem] leading-tight text-ink">
                {it.title}
              </h3>
              <p class="mt-3 text-ink-soft text-[0.9rem] leading-relaxed">
                {it.body}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
