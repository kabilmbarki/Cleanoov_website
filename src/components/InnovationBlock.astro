---
// Innovation & présence forums — texte + timeline horizontale
const events = [
  { date: "Mars 2024", label: "Forum Énergies Tunisie", place: "Tunis" },
  { date: "Sept. 2024", label: "Salon Solaire MENA", place: "Tunis" },
  { date: "Fév. 2025", label: "Conférence ANME", place: "Sfax" },
  { date: "Mai 2025", label: "Forum Innovation Sud", place: "Sousse" },
];
---

<section id="innovation" class="py-24 lg:py-32">
  <div class="container-wide grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
    <div class="lg:col-span-5 reveal">
      <p class="eyebrow">Innovation & R&D</p>
      <h2 class="mt-4">
        Sur le terrain de <span class="italic text-ocre">l'innovation</span>.
      </h2>
      <p class="mt-6 text-ink-soft text-lg leading-relaxed">
        Notre équipe développe en interne ses méthodes d'audit et ses outils de
        diagnostic, et participe régulièrement aux forums professionnels du secteur
        en Tunisie et dans la région MENA.
      </p>
      <a href="/#a-propos" class="mt-8 inline-block btn-ghost text-sm font-medium">
        Découvrir notre démarche →
      </a>
    </div>

    <div class="lg:col-span-7 reveal">
      <div class="relative pl-6 border-l border-ink/15 space-y-10">
        {
          events.map((ev) => (
            <div class="relative">
              <span class="absolute -left-[29px] top-1.5 w-3 h-3 rounded-full bg-cream border-2 border-ocre" />
              <p class="text-xs uppercase tracking-[0.16em] text-graphite font-medium">
                {ev.date} · {ev.place}
              </p>
              <h3 class="mt-2 font-display text-xl text-ink">{ev.label}</h3>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
