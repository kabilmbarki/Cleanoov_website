---
// Innovation timeline — 3 milestones de compétition.
// Display: vertical mobile, parcours horizontal desktop avec ligne lumineuse.

const milestones = [
  {
    n: "01",
    year: "2024",
    title: "Lauréat programme iptic",
    body:
      "Sélectionnés parmi les startups les plus prometteuses du programme d'innovation tunisien iptic, mené par l'INNORPI et ses partenaires.",
    tag: "Programme d'incubation",
    accent: "solar",
  },
  {
    n: "02",
    year: "2025",
    title: "Lauréat concours ctama",
    body:
      "Projet récompensé d'une enveloppe de 100 000 dinars pour accélérer l'industrialisation de nos solutions de nettoyage robotisé.",
    tag: "100 000 TND · Award",
    accent: "solar",
    highlight: true,
  },
  {
    n: "03",
    year: "2026",
    title: "Exposants — JCI World Congress",
    body:
      "Cleanoov sélectionnée comme exposant officiel au congrès mondial JCI, vitrine de l'innovation jeune tunisienne à l'international.",
    tag: "International · Vitrine",
    accent: "leaf",
  },
];
---

<section id="innovation" class="relative py-28 lg:py-36 overflow-hidden">
  <!-- ambient -->
  <div
    class="absolute inset-0 pointer-events-none opacity-40"
    style="background:radial-gradient(700px 400px at 20% 10%, rgba(245,176,65,0.12), transparent 60%), radial-gradient(700px 400px at 90% 80%, rgba(47,191,110,0.10), transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="container-wide relative">
    <div class="max-w-3xl">
      <p class="eyebrow reveal">Distinctions & compétitions</p>
      <h2 class="mt-6 reveal" style="text-wrap: balance;">
        Trois jalons qui ancrent <span class="gradient-solar italic font-semibold">Cleanoov</span>
        dans l'écosystème de l'innovation.
      </h2>
      <p class="mt-6 text-ink-soft text-lg leading-relaxed reveal">
        Lauréats des programmes les plus exigeants de Tunisie, exposants sur la scène
        internationale — chaque étape valide la pertinence de notre approche.
      </p>
    </div>

    <!-- Timeline -->
    <div class="mt-20 lg:mt-24 relative">
      <!-- Glow line desktop -->
      <div
        class="hidden lg:block absolute left-0 right-0 top-[78px] h-px"
        style="background: linear-gradient(90deg, transparent, var(--color-line-strong) 12%, var(--color-solar) 50%, var(--color-leaf) 88%, transparent);"
        aria-hidden="true"
      ></div>

      <ol class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10">
        {
          milestones.map((m) => (
            <li class="relative reveal">
              <!-- Year + node -->
              <div class="flex items-center gap-4 lg:h-[78px]">
                <span
                  class:list={[
                    "font-mono text-xs uppercase tracking-[0.2em]",
                    m.accent === "leaf" ? "text-leaf-bright" : "text-solar-bright",
                  ]}
                >
                  {m.year}
                </span>
                <span class="hidden lg:block flex-1 h-px bg-line"></span>
                <span
                  class:list={[
                    "hidden lg:flex relative w-3.5 h-3.5 rounded-full ring-4 ring-bg",
                    m.accent === "leaf" ? "bg-leaf-bright" : "bg-solar-bright",
                  ]}
                >
                  {m.highlight && (
                    <span class="absolute inset-0 rounded-full bg-solar-bright animate-ping opacity-60"></span>
                  )}
                </span>
              </div>

              <!-- Card -->
              <article
                class:list={[
                  "mt-5 lg:mt-8 surface p-7 lg:p-8 h-full transition-transform duration-500",
                  m.highlight && "ring-1 ring-solar/40",
                ]}
              >
                <header class="flex items-baseline justify-between gap-4">
                  <span class="font-mono text-[0.72rem] tracking-[0.18em] text-ink-muted">
                    {m.n}
                  </span>
                  <span
                    class:list={["chip", m.accent === "leaf" ? "chip-leaf" : "chip-solar"]}
                  >
                    {m.tag}
                  </span>
                </header>
                <h3 class="mt-5 font-display text-2xl lg:text-[1.6rem] text-ink leading-tight">
                  {m.title}
                </h3>
                <p class="mt-4 text-ink-soft text-[0.95rem] leading-relaxed">
                  {m.body}
                </p>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
