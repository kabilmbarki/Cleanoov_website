---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const links = [
  { href: "/a-propos", label: "À propos" },
  { href: "/services", label: "Nos services" },
  { href: "/#succes", label: "Nos succès" },
  { href: "/#publications", label: "Publications" },
  { href: "/#realisations", label: "Réalisations" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

// Extract the pathname portion of a link (strips hash and trailing slash) so
// hash-anchor entries like "/#succes" can match when on the home page.
const linkPath = (href: string) => {
  const noHash = href.split("#")[0] || "/";
  return noHash.replace(/\/$/, "") || "/";
};
---

<header
  id="site-header"
  class:list={[
    "fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter,padding,border-color] duration-300 py-5 lg:py-6 border-b border-transparent",
    transparent && "dark-section",
  ]}
  data-transparent={transparent ? "true" : "false"}
>
  <!-- Scroll progress bar -->
  <div
    id="scroll-progress"
    class="absolute bottom-0 left-0 h-[2px] w-0 bg-gradient-to-r from-leaf to-leaf-bright transition-none pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-wide flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Cleanoov — Accueil">
      <!-- Light logo (white) — used when header sits over the dark hero -->
      <img
        src="/imgs/brand/logo-dark.png"
        alt="Cleanoov"
        class="logo-light h-6 sm:h-7 lg:h-8 w-auto select-none transition-opacity group-hover:opacity-80"
        width="484"
        height="90"
        decoding="async"
      />
      <!-- Dark logo — used when header is solid on light backgrounds -->
      <img
        src="/imgs/brand/logo.png"
        alt="Cleanoov"
        class="logo-dark hidden h-6 sm:h-7 lg:h-8 w-auto select-none transition-opacity group-hover:opacity-80"
        width="484"
        height="90"
        decoding="async"
      />
    </a>

    <nav
      class="hidden md:flex items-center gap-5 lg:gap-9"
      aria-label="Navigation principale"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "text-[0.78rem] lg:text-[0.85rem] font-medium tracking-wide transition-colors whitespace-nowrap",
              path === linkPath(l.href) ? "text-leaf" : "text-ink-soft hover:text-ink",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a
        href="/contact"
        class="hidden md:inline-flex btn btn-primary text-[0.8rem] lg:text-sm py-2 lg:py-2.5 px-4 lg:px-5"
      >
        Devis
      </a>
      <button
        type="button"
        class="burger-btn md:hidden inline-flex flex-col items-center justify-center w-11 h-11 rounded-full border border-line-strong bg-bg-elev/70 backdrop-blur transition-colors"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-toggle
      >
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-line bg-bg-elev/98 backdrop-blur-xl shadow-[0_18px_42px_-22px_rgba(10,26,18,0.30)]"
    data-mobile-menu
  >
    <nav class="container-wide py-4 flex flex-col" aria-label="Navigation mobile">
      {
        links.map((l, i) => {
          const active = path === linkPath(l.href);
          return (
            <a
              href={l.href}
              class:list={[
                "mobile-link group flex items-center justify-between gap-4 py-4 px-1 border-b border-line last:border-0 transition-colors",
                active ? "is-active" : "",
              ]}
            >
              <span class="flex items-center gap-3 min-w-0">
                <span class="font-mono text-[0.66rem] text-ink-muted tracking-[0.18em] uppercase shrink-0">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span class="font-display text-lg leading-tight truncate">{l.label}</span>
              </span>
              <svg
                class="shrink-0 text-ink-muted group-hover:text-leaf transition-colors"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 6l6 6-6 6" />
              </svg>
            </a>
          );
        })
      }
      <a href="/contact" class="btn btn-primary mt-6 mb-2 justify-center">
        Demander un devis
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

{!transparent && <div aria-hidden="true" class="h-20 lg:h-24"></div>}

<style>
  .burger-line {
    display: block;
    width: 1.25rem;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 1px;
    transition: transform 200ms ease, opacity 150ms ease, margin 200ms ease;
  }
  .burger-line + .burger-line { margin-top: 5px; }

  .burger-btn[aria-expanded="true"] .burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .burger-btn[aria-expanded="true"] .burger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .burger-btn[aria-expanded="true"] .burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-link { color: var(--color-ink); }
  .mobile-link:hover { color: var(--color-leaf); }
  .mobile-link.is-active {
    color: var(--color-leaf);
  }
  .mobile-link.is-active span:last-child { color: var(--color-leaf); }
</style>

<script>
  const header = document.getElementById("site-header");
  const transparent = header?.dataset.transparent === "true";
  const SOLID = [
    "bg-bg-elev/85",
    "backdrop-blur-xl",
    "py-3",
    "lg:py-4",
    "border-line",
  ];
  const AIRY = ["py-5", "lg:py-6"];

  const setLogo = (showLight: boolean) => {
    const light = header?.querySelector<HTMLImageElement>(".logo-light");
    const dark = header?.querySelector<HTMLImageElement>(".logo-dark");
    if (!light || !dark) return;
    light.classList.toggle("hidden", !showLight);
    dark.classList.toggle("hidden", showLight);
  };

  // Non-transparent pages always show dark logo (light header on light page)
  if (!transparent) setLogo(false);

  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 24;
    if (scrolled) {
      header.classList.add(...SOLID);
      header.classList.remove(...AIRY);
      // When scrolled the header is on a light surface — disable dark-section override
      if (transparent) header.classList.remove("dark-section");
      setLogo(false);
    } else {
      header.classList.remove(...SOLID);
      header.classList.add(...AIRY);
      if (transparent) {
        header.classList.add("dark-section");
        setLogo(true);
      }
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const isOpen = menu.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Fermer le menu" : "Ouvrir le menu");
    document.body.style.overflow = isOpen ? "hidden" : "";
  });
  document.querySelectorAll("[data-mobile-menu] a").forEach((a) => {
    a.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Ouvrir le menu");
      document.body.style.overflow = "";
    });
  });

  // Scroll progress bar
  const progressBar = document.getElementById("scroll-progress");
  if (progressBar) {
    const updateProgress = () => {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? (scrolled / total) * 100 : 0;
      progressBar.style.width = pct + "%";
    };
    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  }
</script>
