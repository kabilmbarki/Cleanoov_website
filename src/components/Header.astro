---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;

const links = [
  { href: "/#innovation", label: "Innovation" },
  { href: "/#publications", label: "Publications" },
  { href: "/#realisations", label: "Réalisations" },
  { href: "/services", label: "Services" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header
  id="site-header"
  class:list={[
    "fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter,padding,border-color] duration-300 py-5 lg:py-6 border-b border-transparent",
  ]}
  data-transparent={transparent ? "true" : "false"}
>
  <div class="container-wide flex items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-3 group" aria-label="Cleanoov — Accueil">
      <img
        src="/imgs/brand/logo-dark.png"
        alt="Cleanoov"
        class="h-9 lg:h-10 w-auto select-none transition-opacity group-hover:opacity-80"
        width="500"
        height="500"
        decoding="async"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-9" aria-label="Navigation principale">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "text-[0.85rem] font-medium tracking-wide transition-colors",
              path === l.href ? "text-solar" : "text-ink-soft hover:text-ink",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="/contact" class="hidden sm:inline-flex btn btn-primary text-sm py-2.5 px-5">
        Devis
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex flex-col items-center justify-center w-11 h-11 rounded-full border border-line-strong bg-bg-elev/70 backdrop-blur"
        aria-label="Menu"
        aria-expanded="false"
        data-mobile-toggle
      >
        <span class="block w-5 h-px bg-ink mb-1.5"></span>
        <span class="block w-5 h-px bg-ink"></span>
      </button>
    </div>
  </div>

  <div
    class="lg:hidden hidden border-t border-line bg-bg-elev/95 backdrop-blur-xl"
    data-mobile-menu
  >
    <nav class="container-wide py-6 flex flex-col gap-1" aria-label="Navigation mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="block py-3 text-base font-medium text-ink-soft border-b border-line last:border-0 hover:text-solar"
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contact" class="btn btn-primary mt-5 self-start">
        Demander un devis
      </a>
    </nav>
  </div>
</header>

{!transparent && <div aria-hidden="true" class="h-20 lg:h-24"></div>}

<script>
  const header = document.getElementById("site-header");
  const SOLID = [
    "bg-bg-elev/85",
    "backdrop-blur-xl",
    "py-3",
    "lg:py-4",
    "border-line",
  ];
  const AIRY = ["py-5", "lg:py-6"];
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add(...SOLID);
      header.classList.remove(...AIRY);
    } else {
      header.classList.remove(...SOLID);
      header.classList.add(...AIRY);
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const isOpen = menu.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
  document.querySelectorAll("[data-mobile-menu] a").forEach((a) => {
    a.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
