---
const links = [
  { href: "/services", label: "Services" },
  { href: "/#realisations", label: "Réalisations" },
  { href: "/#innovation", label: "Innovation" },
  { href: "/#a-propos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];
const path = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-[background-color,backdrop-filter,padding] duration-300 py-5 lg:py-6"
  data-header
>
  <div class="container-wide flex items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-3 group" aria-label="Cleanoov — Accueil">
      <span
        class="font-display text-2xl lg:text-[1.7rem] tracking-tight text-ink transition-colors group-hover:text-ocre"
      >
        Cleanoov<span class="text-ocre">.</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigation principale">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              "text-sm font-medium tracking-wide hover:text-ocre transition-colors",
              path === l.href ? "text-ocre" : "text-ink",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href="/contact" class="hidden sm:inline-flex btn btn-primary text-sm">
        Demander un devis
      </a>
      <button
        type="button"
        class="lg:hidden inline-flex flex-col items-center justify-center w-11 h-11 rounded-full border border-ink/15 bg-cream/70 backdrop-blur"
        aria-label="Menu"
        aria-expanded="false"
        data-mobile-toggle
      >
        <span class="block w-5 h-px bg-ink mb-1.5 transition-transform"></span>
        <span class="block w-5 h-px bg-ink transition-transform"></span>
      </button>
    </div>
  </div>

  <div
    class="lg:hidden hidden border-t border-ink/10 bg-cream/95 backdrop-blur"
    data-mobile-menu
  >
    <nav class="container-wide py-6 flex flex-col gap-1" aria-label="Navigation mobile">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="block py-3 text-base font-medium border-b border-ink/5 last:border-0 hover:text-ocre"
          >
            {l.label}
          </a>
        ))
      }
      <a href="/contact" class="btn btn-primary mt-4 self-start">
        Demander un devis
      </a>
    </nav>
  </div>
</header>

<div aria-hidden="true" class="h-20 lg:h-24"></div>

<script>
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 16) {
      header.classList.add(
        "bg-cream/85",
        "backdrop-blur-md",
        "py-3",
        "lg:py-4",
        "shadow-[0_1px_0_0_rgba(15,26,36,0.06)]"
      );
      header.classList.remove("py-5", "lg:py-6");
    } else {
      header.classList.remove(
        "bg-cream/85",
        "backdrop-blur-md",
        "py-3",
        "lg:py-4",
        "shadow-[0_1px_0_0_rgba(15,26,36,0.06)]"
      );
      header.classList.add("py-5", "lg:py-6");
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const isOpen = menu.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
  document.querySelectorAll("[data-mobile-menu] a").forEach((a) => {
    a.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
