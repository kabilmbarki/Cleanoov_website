---
// AboutSection — slim teaser on the home page that links to /a-propos.
// Right column shows a Cleanoov YouTube field video (lite-embed: thumbnail
// + play overlay; iframe only loads on click for performance).

const videoId = "Arjrj2yZd0c";
const videoUrl = `https://www.youtube.com/watch?v=${videoId}`;

const stats = [
  { count: 25,    prefix: "+", suffix: " %",  display: "+25 %",    label: "rendement restauré sur des panneaux encrassés" },
  { count: 2,     prefix: "",  suffix: "",     display: "2",         label: "prix nationaux remportés — iptic & ctama" },
  { count: 30000, prefix: "",  suffix: "",     display: "30 000",    label: "panneaux pilotés sur notre premier site industriel · Maknassi, 10 MW" },
  { count: 500,   prefix: "",  suffix: " MW",  display: "500 MW",    label: "de capacité solaire installée en Tunisie — notre marché cible" },
];
---

<section
  id="a-propos"
  class="relative py-14 lg:py-20 border-t border-line overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(700px_400px_at_92%_10%,rgba(43,182,115,0.06),transparent_60%)] pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-wide relative">
    <p class="eyebrow reveal">À propos · Cleanoov</p>

    <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <!-- Left: heading + CTA -->
      <div class="lg:col-span-7 reveal">
        <h2
          class="font-display text-[1.7rem] sm:text-[2rem] lg:text-[2.4rem] xl:text-[2.6rem] leading-[1.15] tracking-tight"
          style="text-wrap: balance;"
        >
          Cleanoov conçoit des
          <span class="gradient-leaf italic font-semibold">robots intelligents et des solutions IA</span>
          pour restaurer le rendement des centrales solaires —
          <span class="text-ink">fondée par des ingénieurs tunisiens qui connaissent le terrain.</span>
        </h2>

        <div class="mt-10">
          <a href="/a-propos" class="btn btn-primary inline-flex items-center gap-2">
            Découvrir qui nous sommes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: YouTube lite-embed (field video) -->
      <div
        id="about-video"
        class="lg:col-span-5 reveal relative rounded-2xl overflow-hidden border border-leaf/40 shadow-[0_24px_48px_-24px_rgba(10,26,18,0.30)] aspect-video bg-bg-elev"
        data-video-id={videoId}
      >
        <button
          type="button"
          id="about-video-trigger"
          class="absolute inset-0 w-full h-full group cursor-pointer"
          aria-label="Lancer la vidéo Cleanoov sur YouTube"
        >
          <img
            src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`}
            onerror={`this.onerror=null;this.src='https://img.youtube.com/vi/${videoId}/hqdefault.jpg';`}
            alt="Cleanoov en action sur le terrain — chantier de nettoyage de panneaux solaires en Tunisie · vidéo YouTube"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
            loading="lazy"
            width="1280"
            height="720"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,18,13,0.10)_0%,rgba(7,18,13,0.30)_50%,rgba(7,18,13,0.85)_100%)] pointer-events-none transition-opacity duration-300 group-hover:opacity-90"
            aria-hidden="true"
          ></div>

          <!-- Play button overlay -->
          <span
            class="absolute inset-0 flex items-center justify-center pointer-events-none"
            aria-hidden="true"
          >
            <span class="relative w-16 h-16 sm:w-20 sm:h-20 lg:w-24 lg:h-24 rounded-full bg-leaf/95 group-hover:bg-leaf-bright shadow-[0_0_0_8px_rgba(43,182,115,0.18),0_0_0_18px_rgba(43,182,115,0.10)] transition-all duration-300 flex items-center justify-center">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="white" class="ml-1">
                <path d="M5 3l14 8-14 8V3z"/>
              </svg>
            </span>
          </span>

          <!-- Caption -->
          <span class="absolute left-4 right-4 bottom-4 sm:left-5 sm:right-5 sm:bottom-5 text-left">
            <span class="inline-flex items-center gap-1.5 bg-white text-ink py-1 px-2.5 rounded-full font-mono text-[0.62rem] sm:text-[0.65rem] uppercase tracking-[0.16em] font-medium shadow-[0_2px_10px_rgba(7,18,13,0.35)]">
              <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-leaf">
                <path d="M5 3l14 8-14 8V3z"/>
              </svg>
              Vidéo · YouTube
            </span>
            <span class="block mt-3 font-display text-base sm:text-lg text-white leading-snug">
              Cleanoov en action sur le terrain
            </span>
          </span>
        </button>

        <!-- Fallback link for users without JS / when iframe fails -->
        <noscript>
          <a
            href={videoUrl}
            target="_blank"
            rel="noopener"
            class="absolute inset-0 z-10"
            aria-label="Voir la vidéo sur YouTube"
          ></a>
        </noscript>
      </div>
    </div>
  </div>

  <div class="container-wide mt-14 lg:mt-18 relative" id="stats-block">
    <dl class="grid grid-cols-2 gap-px bg-line border border-line rounded-xl overflow-hidden">
      {
        stats.map((s) => (
          <div class="bg-bg-elev px-5 py-7 sm:px-7 sm:py-9 lg:px-9 lg:py-11 reveal">
            <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-ink-muted">
              Indicateur
            </dt>
            <dd
              class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl text-ink leading-[1] tracking-tight"
              data-count={s.count}
              data-prefix={s.prefix}
              data-suffix={s.suffix}
            >
              {s.display}
            </dd>
            <p class="mt-3 text-ink-soft text-xs sm:text-sm leading-relaxed">
              {s.label}
            </p>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<script>
  // Lite YouTube embed
  const trigger = document.getElementById("about-video-trigger");
  const wrapper = document.getElementById("about-video");
  if (trigger && wrapper) {
    trigger.addEventListener("click", () => {
      const id = wrapper.dataset.videoId;
      if (!id) return;
      const iframe = document.createElement("iframe");
      iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`;
      iframe.title = "Cleanoov — chantier de nettoyage de panneaux photovoltaïques";
      iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
      iframe.setAttribute("allowfullscreen", "");
      iframe.className = "absolute inset-0 w-full h-full border-0";
      wrapper.replaceChildren(iframe);
    });
  }

  // Count-up animation
  const fmt = (n: number) => n >= 1000 ? n.toLocaleString("fr-FR") : String(n);
  const easeOut = (t: number) => 1 - Math.pow(1 - t, 4);

  const animateStat = (el: HTMLElement) => {
    const target = parseInt(el.dataset.count || "0", 10);
    const prefix = el.dataset.prefix || "";
    const suffix = el.dataset.suffix || "";
    const duration = target >= 10000 ? 2200 : 1600;
    const start = performance.now();
    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const value = Math.round(easeOut(progress) * target);
      el.textContent = prefix + fmt(value) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const statsBlock = document.getElementById("stats-block");
  if (statsBlock) {
    const obs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        statsBlock.querySelectorAll<HTMLElement>("dd[data-count]").forEach(animateStat);
        obs.disconnect();
      }
    }, { threshold: 0.3 });
    obs.observe(statsBlock);
  }
</script>
