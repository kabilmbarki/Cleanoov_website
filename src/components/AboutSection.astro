---
// AboutSection — slim teaser on the home page that links to /a-propos.
// The full Vision / Mission / Valeurs editorial lives on the dedicated page.

const stats = [
  { value: "+25 %", label: "rendement restauré sur des panneaux encrassés" },
  { value: "Lauréats", label: "du concours national ctama · édition 2025" },
  { value: "3 ans", label: "d'innovation continue depuis le lancement" },
];
---

<section
  id="a-propos"
  class="relative py-24 lg:py-32 border-t border-line overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(700px_400px_at_92%_10%,rgba(43,182,115,0.06),transparent_60%)] pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-wide relative">
    <p class="eyebrow reveal">À propos · Cleanoov</p>

    <div class="mt-10 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center">
      <!-- Left: heading + CTA -->
      <div class="lg:col-span-7 reveal">
        <h2
          class="font-display text-[1.7rem] sm:text-[2rem] lg:text-[2.4rem] xl:text-[2.6rem] leading-[1.15] tracking-tight"
          style="text-wrap: balance;"
        >
          Cleanoov est une
          <span class="gradient-leaf italic font-semibold">startup tunisienne innovante</span>,
          spécialisée dans les solutions d'<span class="text-ink">optimisation des rendements</span>
          des installations photovoltaïques.
        </h2>

        <div class="mt-10">
          <a href="/a-propos" class="btn btn-primary inline-flex items-center gap-2">
            Découvrir qui nous sommes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: dust image showing the problem -->
      <figure class="lg:col-span-5 reveal relative rounded-2xl overflow-hidden border border-line shadow-[0_24px_48px_-24px_rgba(10,26,18,0.25)]">
        <img
          src="/imgs/illustrations/encrassement.jpg"
          alt="Main couverte de poussière passée sur un panneau photovoltaïque très encrassé — Cleanoov, problème de soiling en Tunisie"
          class="block w-full h-auto"
          loading="lazy"
          width="1205"
          height="625"
        />
        <div
          class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,18,13,0)_0%,rgba(7,18,13,0.10)_50%,rgba(7,18,13,0.85)_100%)] pointer-events-none"
          aria-hidden="true"
        ></div>
        <figcaption class="absolute left-4 right-4 bottom-4 sm:left-5 sm:right-5 sm:bottom-5">
          <span class="chip chip-leaf text-[0.62rem] sm:text-[0.65rem] py-1 px-2.5">
            Le problème · L'encrassement
          </span>
          <p class="mt-3 text-white text-sm sm:text-[0.95rem] leading-snug max-w-md">
            Sable, poussière, suie — chaque mois sans nettoyage coûte
            2 à 5 % de production solaire en Tunisie.
          </p>
        </figcaption>
      </figure>
    </div>
  </div>

  <div class="container-wide mt-20 lg:mt-24 relative">
    <dl class="grid grid-cols-1 md:grid-cols-3 gap-px bg-line border border-line rounded-xl overflow-hidden">
      {
        stats.map((s) => (
          <div class="bg-bg-elev px-8 py-10 lg:px-10 lg:py-14 reveal">
            <dt class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-ink-muted">
              Indicateur
            </dt>
            <dd class="mt-4 font-display text-4xl lg:text-5xl xl:text-6xl text-ink leading-[1] tracking-tight">
              {s.value}
            </dd>
            <p class="mt-4 text-ink-soft text-sm max-w-xs leading-relaxed">
              {s.label}
            </p>
          </div>
        ))
      }
    </dl>
  </div>
</section>
