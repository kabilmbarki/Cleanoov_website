---
// AboutSection — slim teaser on the home page that links to /a-propos.
// The full Vision / Mission / Valeurs editorial lives on the dedicated page.

const stats = [
  { value: "+25 %", label: "rendement restauré sur des panneaux encrassés" },
  { value: "Lauréats", label: "du concours national ctama · édition 2025" },
  { value: "3 ans", label: "d'innovation continue depuis le lancement" },
];
---

<section
  id="a-propos"
  class="relative py-24 lg:py-32 border-t border-line overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(700px_400px_at_92%_10%,rgba(43,182,115,0.06),transparent_60%)] pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-narrow relative">
    <p class="eyebrow reveal">À propos · Cleanoov</p>

    <h2
      class="mt-8 font-display text-[2rem] sm:text-[2.6rem] lg:text-[3.2rem] leading-[1.1] tracking-tight reveal"
      style="text-wrap: balance;"
    >
      Une <span class="gradient-leaf italic font-semibold">startup tunisienne</span>
      qui repense l'<span class="text-ink-muted">optimisation</span> du solaire.
    </h2>

    <p class="mt-7 max-w-2xl text-lg text-ink-soft leading-relaxed reveal">
      La rigueur d'un labo au service des centrales photovoltaïques —
      du nettoyage robotisé au diagnostic piloté par IA.
    </p>

    <div class="mt-10 reveal">
      <a href="/a-propos" class="btn btn-primary inline-flex items-center gap-2">
        Découvrir qui nous sommes
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="container-wide mt-20 lg:mt-24 relative">
    <dl class="grid grid-cols-1 md:grid-cols-3 gap-px bg-line border border-line rounded-xl overflow-hidden">
      {
        stats.map((s) => (
          <div class="bg-bg-elev px-8 py-10 lg:px-10 lg:py-14 reveal">
            <dt class="font-mono text-[0.72rem] uppercase tracking-[0.18em] text-ink-muted">
              Indicateur
            </dt>
            <dd class="mt-4 font-display text-4xl lg:text-5xl xl:text-6xl text-ink leading-[1] tracking-tight">
              {s.value}
            </dd>
            <p class="mt-4 text-ink-soft text-sm max-w-xs leading-relaxed">
              {s.label}
            </p>
          </div>
        ))
      }
    </dl>
  </div>
</section>
