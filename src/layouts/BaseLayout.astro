---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AboutPopup from "../components/AboutPopup.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Optional alt text for the OG/Twitter image */
  imageAlt?: string;
  /** When true, the page renders a full-bleed hero behind the header (no top padding) */
  transparentHeader?: boolean;
}

const {
  title = "Cleanoov — Innovation solaire tunisienne",
  description = "Cleanoov, jeune startup tunisienne lauréate iptic et ctama — nettoyage, diagnostic et maintenance préventive de centrales photovoltaïques pour accélérer la transition énergétique.",
  image = "/og-image.jpg",
  imageAlt = "Cleanoov — technicien nettoyant des panneaux photovoltaïques avec brosse rotative en Tunisie · innovation solaire",
  transparentHeader = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const absImage = new URL(image, Astro.site).toString();

// JSON-LD — multi-schema graph for rich results / local SEO / sitelinks
const siteUrl = Astro.site?.toString() ?? "https://cleanoov.tn/";
const logoUrl = new URL("/imgs/brand/logo.png", siteUrl).toString();

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}#business`,
  name: "Cleanoov",
  alternateName: "Cleanoov — Innovation solaire tunisienne",
  url: siteUrl,
  logo: logoUrl,
  image: absImage,
  description,
  foundingDate: "2023",
  email: "contact@cleanoov.tn",
  telephone: "+216 00 000 000",
  priceRange: "€€",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Tunis",
    addressRegion: "Tunis",
    addressCountry: "TN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 36.8065,
    longitude: 10.1815,
  },
  areaServed: [
    { "@type": "Country", name: "Tunisia" },
    { "@type": "City", name: "Tunis" },
    { "@type": "City", name: "Sousse" },
    { "@type": "City", name: "Sfax" },
    { "@type": "City", name: "Monastir" },
    { "@type": "City", name: "Béjà" },
  ],
  knowsAbout: [
    "Nettoyage de panneaux solaires",
    "Maintenance photovoltaïque",
    "Diagnostic thermique infrarouge",
    "Robotique pour le solaire",
    "Innovation cleantech",
    "Startup tunisienne",
  ],
  sameAs: [
    "https://www.facebook.com/profile.php?id=61577362184751",
    "https://www.instagram.com/cleanoov/",
    "https://www.youtube.com/@BayoudhSoulaymen",
  ],
  award: [
    "Lauréat du programme iptic — INNORPI (2024)",
    "Lauréat du concours national ctama (2025)",
    "Exposants — JCI World Congress (2026)",
  ],
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Services Cleanoov",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          "@id": `${siteUrl}services#nettoyage-semi-auto`,
          name: "Nettoyage semi-automatique des panneaux solaires",
          description:
            "Système de brosses semi-automatiques pour un nettoyage efficace, rapide et économe en eau, qui préserve la surface des panneaux photovoltaïques.",
          areaServed: { "@type": "Country", name: "Tunisia" },
          provider: { "@id": `${siteUrl}#business` },
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          "@id": `${siteUrl}services#robot`,
          name: "Robot de nettoyage pour grandes installations photovoltaïques",
          description:
            "Solution automatisée pour centrales solaires et grandes surfaces — réduit coûts et temps d'intervention, améliore le rendement énergétique.",
          areaServed: { "@type": "Country", name: "Tunisia" },
          provider: { "@id": `${siteUrl}#business` },
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          "@id": `${siteUrl}services#maintenance`,
          name: "Maintenance des installations photovoltaïques",
          description:
            "Inspection, mesures électriques et contrôle périodique des systèmes PV pour garantir leur bon fonctionnement et détecter les anomalies techniques.",
          areaServed: { "@type": "Country", name: "Tunisia" },
          provider: { "@id": `${siteUrl}#business` },
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          "@id": `${siteUrl}services#diagnostic-preventif`,
          name: "Diagnostic et maintenance préventive photovoltaïque",
          description:
            "Imagerie thermique IR, analyse régulière des performances et alertes anticipées — pour anticiper les pertes de rendement et sécuriser la production sur le long terme.",
          areaServed: { "@type": "Country", name: "Tunisia" },
          provider: { "@id": `${siteUrl}#business` },
        },
      },
    ],
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  name: "Cleanoov",
  alternateName: "Cleanoov — Innovation solaire tunisienne",
  url: siteUrl,
  description,
  publisher: { "@id": `${siteUrl}#business` },
  inLanguage: "fr-TN",
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicons & PWA icons -->
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/icons/favicon-48x48.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
    <link rel="mask-icon" href="/icons/favicon.svg" color="#1A7A4F" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="application-name" content="Cleanoov" />
    <meta name="apple-mobile-web-app-title" content="Cleanoov" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="msapplication-TileColor" content="#1A7A4F" />
    <meta name="msapplication-config" content="none" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Cleanoov" />
    <meta name="keywords" content="nettoyage panneaux solaires, photovoltaïque, Tunisie, maintenance préventive, diagnostic thermique, ctama, iptic, énergie solaire, soiling, rendement panneaux" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Cleanoov" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={absImage} />
    <meta property="og:image:secure_url" content={absImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Fonts: Space Grotesk (display) + Inter (body) + JetBrains Mono (mono accents) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta name="theme-color" content="#FAFAF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#07120D" media="(prefers-color-scheme: dark)" />

    <!-- Structured data — LocalBusiness + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body class="min-h-screen bg-bg text-ink antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-solar focus:text-bg focus:px-4 focus:py-2 focus:rounded-full"
    >
      Aller au contenu
    </a>

    <Header transparent={transparentHeader} />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <AboutPopup />

    <script>
      const reveal = () => {
        const els = document.querySelectorAll<HTMLElement>(".reveal");
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach((el) => io.observe(el));
      };
      document.addEventListener("DOMContentLoaded", reveal);
    </script>
  </body>
</html>
